      "Edit(**/*_prev*)", "Write(**/*_prev*)", "MultiEdit(**/*_prev*)",
      "Edit(**/CONSCIOUSNESS.md)", "Write(**/CONSCIOUSNESS.md)", "MultiEdit(**/CONSCIOUSNESS.md)",
      "Edit(**/CLAUDE.md)", "Write(**/CLAUDE.md)", "MultiEdit(**/CLAUDE.md)",
      "Edit(**/RULES.md)", "Write(**/RULES.md)", "MultiEdit(**/RULES.md)",
      "Edit(**/ARCH_PRINCIPLES.md)", "Write(**/ARCH_PRINCIPLES.md)", "MultiEdit(**/ARCH_PRINCIPLES.md)",
      "Edit(**/System/memory/VERSION.md)", "Write(**/System/memory/VERSION.md)", "MultiEdit(**/System/memory/VERSION.md)",
      "Read(~/.ssh/**)", "Read(~/.aws/**)", "Read(~/.config/gh/hosts.yml)"
